# FormFill MCP — environment variable template
# Copy to .env and fill in real values. Never commit .env to version control.

# ── Stripe ──────────────────────────────────────────────────────────────────
# Secret key — Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=your-stripe-secret-key-here

# Webhook signing secret — Stripe Dashboard → Developers → Webhooks → your endpoint
# Endpoint to register: https://formfill.plenitudo.ai/webhook/stripe
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# The Stripe Price ID for the Pro plan — create a Product + Recurring Price in Stripe
STRIPE_PRO_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx

# ── FormFill config ──────────────────────────────────────────────────────────
# Free-tier monthly cap (default: 10)
# FREE_MONTHLY_LIMIT=10

# Data directory (default: ./data — relative to server.py)
FORMFILL_DATA_DIR=./data

# Log file location
# FORMFILL_LOG_FILE=./logs/server.log

# Log level: DEBUG | INFO | WARNING | ERROR (default: INFO)
# LOG_LEVEL=INFO

# URL shown in "upgrade" error messages
# UPGRADE_URL=https://formfill.plenitudo.ai

# ── x402 Micropayments (USDC on Base) ─────────────────────────────────────
X402_WALLET_ADDRESS=0x9053FeDC90c1BCB4a8Cf708DdB426aB02430d6ad
X402_PRICE_USDC=0.05
BASE_RPC_URL=https://mainnet.base.org
