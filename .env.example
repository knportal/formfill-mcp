# FormFill MCP — environment variable template
# Copy to .env and fill in real values. Never commit .env to version control.

# ── Stripe ──────────────────────────────────────────────────────────────────
# Found in your Stripe Dashboard → Developers → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# The Stripe Price ID for the Pro plan ($9.99/month)
STRIPE_PRO_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx

# ── FormFill config ──────────────────────────────────────────────────────────
# Override the default free-tier monthly cap (default: 50)
# FREE_MONTHLY_LIMIT=50

# Override the DB directory (default: ~/Projects/formfill-mcp/data/)
# FORMFILL_DB_PATH=/var/formfill/data/

# Override the log file location (default: ~/Projects/formfill-mcp/logs/server.log)
# FORMFILL_LOG_FILE=/var/log/formfill/server.log

# Log level: DEBUG | INFO | WARNING | ERROR (default: INFO)
# LOG_LEVEL=INFO

# Port for the Stripe webhook Flask server (default: 8090)
# STRIPE_WEBHOOK_PORT=8090

# URL shown in "upgrade" error messages
# UPGRADE_URL=https://formfill.plenitudo.ai

# ── x402 Micropayments (USDC on Base) ─────────────────────────────────────
X402_WALLET_ADDRESS=0x9053FeDC90c1BCB4a8Cf708DdB426aB02430d6ad
X402_PRICE_USDC=0.001
BASE_RPC_URL=https://mainnet.base.org
